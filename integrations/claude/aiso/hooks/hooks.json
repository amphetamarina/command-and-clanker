{
  "_comment": "Streams Claude Code activity to AIso. AISO_SESSION/AISO_TOKEN are injected into the shell environment by the AIso terminal that launched this agent; they tag the event with its terminal island and authorize the local ingest endpoint. The endpoint acks instantly so these hooks do not block the agent.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:3001/ingest",
            "headers": {
              "Authorization": "Bearer $AISO_TOKEN",
              "X-Aiso-Session": "$AISO_SESSION"
            },
            "allowedEnvVars": ["AISO_TOKEN", "AISO_SESSION"]
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:3001/ingest",
            "headers": {
              "Authorization": "Bearer $AISO_TOKEN",
              "X-Aiso-Session": "$AISO_SESSION"
            },
            "allowedEnvVars": ["AISO_TOKEN", "AISO_SESSION"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:3001/ingest",
            "headers": {
              "Authorization": "Bearer $AISO_TOKEN",
              "X-Aiso-Session": "$AISO_SESSION"
            },
            "allowedEnvVars": ["AISO_TOKEN", "AISO_SESSION"]
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:3001/ingest",
            "headers": {
              "Authorization": "Bearer $AISO_TOKEN",
              "X-Aiso-Session": "$AISO_SESSION"
            },
            "allowedEnvVars": ["AISO_TOKEN", "AISO_SESSION"]
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:3001/ingest",
            "headers": {
              "Authorization": "Bearer $AISO_TOKEN",
              "X-Aiso-Session": "$AISO_SESSION"
            },
            "allowedEnvVars": ["AISO_TOKEN", "AISO_SESSION"]
          }
        ]
      }
    ]
  }
}
