{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:3001/ingest",
            "headers": {
              "Authorization": "Bearer $AISO_TOKEN",
              "X-Aiso-Session": "$AISO_SESSION"
            },
            "allowedEnvVars": ["AISO_TOKEN", "AISO_SESSION"]
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:3001/ingest",
            "headers": {
              "Authorization": "Bearer $AISO_TOKEN",
              "X-Aiso-Session": "$AISO_SESSION"
            },
            "allowedEnvVars": ["AISO_TOKEN", "AISO_SESSION"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:3001/ingest",
            "headers": {
              "Authorization": "Bearer $AISO_TOKEN",
              "X-Aiso-Session": "$AISO_SESSION"
            },
            "allowedEnvVars": ["AISO_TOKEN", "AISO_SESSION"]
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:3001/ingest",
            "headers": {
              "Authorization": "Bearer $AISO_TOKEN",
              "X-Aiso-Session": "$AISO_SESSION"
            },
            "allowedEnvVars": ["AISO_TOKEN", "AISO_SESSION"]
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:3001/ingest",
            "headers": {
              "Authorization": "Bearer $AISO_TOKEN",
              "X-Aiso-Session": "$AISO_SESSION"
            },
            "allowedEnvVars": ["AISO_TOKEN", "AISO_SESSION"]
          }
        ]
      }
    ]
  }
}
